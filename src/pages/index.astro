---
import Layout from "@layouts/Default.astro";
import { modules } from "../data/modules";

const agentModules = modules.map(
	({ slug, name, emoji, tagline, description, docs, repo, status, stack }) => ({
		slug,
		name,
		emoji,
		tagline,
		description,
		docs,
		repo,
		status,
		stack,
	}),
);

const GH_SVG = `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`;
---

<Layout
  title='Coral | Open Source Jellyfin Ecosystem Modules'
  description='Coral is an open source Jellyfin ecosystem: independent Docker-native modules like Aurora, KAPOW, Fathom, Marquee, Encore, and Librarian.'
>
  <!-- NAV -->
  <nav class='site-nav'>
    <a href='/' class='nav-logo'>
      <span>🪸</span>
      <span class='nav-logo-text'>Coral</span>
    </a>
    <div class='nav-links'>
      <a href='#modules' class='nav-pill'>Modules</a>
      <a href='#principles' class='nav-pill'>Philosophy</a>
      <a href='/stats' class='nav-pill'>Stats</a>
      <a
        href='https://github.com/Get-Coral'
        target='_blank'
        class='nav-pill nav-pill-icon'
      >
        <Fragment set:html={GH_SVG} />
        <span class='nav-gh-text'>GitHub</span>
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class='hero'>
    <div class='glow-coral' style='top: -150px; left: -150px;'></div>
    <div class='glow-teal' style='bottom: -100px; right: -100px;'></div>

    <div class='hero-inner'>
      <div class='animate-fade-up delay-1 hero-badge'>
        <span>🪸</span> Open Source Jellyfin Ecosystem
      </div>

      <h1 class='animate-fade-up delay-2 hero-title'>
        Your media server.<br />
        <em>Reimagined.</em>
      </h1>

      <p class='animate-fade-up delay-3 hero-sub'>
        A reef of independent modules and shared packages that extend Jellyfin
        with modern UX. Build your own with
        <code>pnpm create coral@latest</code> and reuse components with
        <code>@get-coral/ui</code>.
      </p>

      <div class='animate-fade-up delay-4 hero-ctas'>
        <a href='#modules' class='btn-primary'>Explore modules</a>
        <a
          href='https://docs.getcoral.dev/getting-started/create-coral/'
          class='btn-ghost'>Scaffold with the CLI</a
        >
        <a href='https://docs.getcoral.dev/libraries/coral-ui/' class='btn-ghost'
          >Explore Coral UI</a
        >
        <a
          href='https://github.com/Get-Coral'
          target='_blank'
          class='btn-ghost'
        >
          <Fragment set:html={GH_SVG} />
          View on GitHub
        </a>
      </div>

      <div class='animate-fade-up delay-5 stats-row'>
        <div class='stat'>
          <div class='stat-value' style='color: var(--coral);'>7</div>
          <div class='stat-label'>Modules</div>
        </div>
        <div class='stat-divider'></div>
        <div class='stat'>
          <div class='stat-value' style='color: var(--teal);'>MIT</div>
          <div class='stat-label'>Licensed</div>
        </div>
        <div class='stat-divider'></div>
        <div class='stat'>
          <div class='stat-value'>∞</div>
          <div class='stat-label'>No quotas</div>
        </div>
        <div class='stat-divider'></div>
        <div class='stat'>
          <div class='stat-value' style='color: var(--teal);'>CLI</div>
          <div class='stat-label'>create-coral</div>
        </div>
        <div class='stat-divider'></div>
        <div class='stat'>
          <div class='stat-value' style='color: var(--coral);'>5</div>
          <div class='stat-label'>NPM packages</div>
        </div>
        <div class='stat-divider'></div>
        <div class='stat'>
          <div class='stat-value'>🐳</div>
          <div class='stat-label'>Docker native</div>
        </div>
      </div>
    </div>
  </section>

  <!-- MODULES -->
  <section id='modules' class='section-modules'>
    <div class='reveal section-header'>
      <p class='section-eyebrow' style='color: var(--teal);'>The Reef</p>
      <h2 class='section-title'>
        Every module is independent.<br /><span class='section-title-muted'
          >Together they're an ecosystem.</span
        >
      </h2>
      <p class='section-sub'>
        Each one runs as a Docker container, talks to your Jellyfin server, and
        does one thing brilliantly.
      </p>
    </div>

    <div class='modules-grid'>
	      {
	        modules.map((mod, i) => (
	          <div
	            class={`module-card ${mod.accent}-accent reveal`}
	            style={`animation-delay: ${i * 0.07}s`}
	          >
	            <a
	              href={`/apps/${mod.slug}`}
	              class='module-card-overlay'
	              aria-label={`Open ${mod.name} page`}
	            ></a>
	            <div class='card-header'>
	              <span class='card-emoji'>{mod.emoji}</span>
	            </div>
	            <h3 class='card-title'>{mod.name}</h3>
            <p class='card-tagline'>{mod.tagline}</p>
            <p class='card-desc'>{mod.description}</p>
            <div class='card-actions'>
              <a href={mod.docs} class='card-link'>
                Read docs
              </a>
              <a href={mod.repo} target='_blank' class='card-link'>
                <Fragment set:html={GH_SVG} />
                View repo
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- PACKAGES -->
  <section class='section-philosophy'>
    <div class='section-inner'>
      <div class='reveal section-header'>
        <p class='section-eyebrow' style='color: var(--teal);'>Shared Packages</p>
        <h2 class='section-title'>Build once, reuse everywhere.</h2>
        <p class='section-sub'>
          Coral also ships reusable NPM packages so modules can share UI,
          typed APIs, and tooling standards.
        </p>
      </div>

      <div class='principles-grid'>
        <div class='reveal principle-card'>
          <div class='principle-icon'>🧩</div>
          <h3 class='principle-title'>@get-coral/ui</h3>
          <p class='principle-body'>
            Shared React component library and design tokens for consistent Coral
            interfaces.
          </p>
          <a href='https://docs.getcoral.dev/libraries/coral-ui/' class='card-link'>
            Read docs
          </a>
        </div>

        <div class='reveal principle-card'>
          <div class='principle-icon'>🔌</div>
          <h3 class='principle-title'>@get-coral/jellyfin</h3>
          <p class='principle-body'>
            Typed Jellyfin API client used across Coral modules and custom apps.
          </p>
          <a href='https://docs.getcoral.dev/libraries/jellyfin/' class='card-link'>
            Read docs
          </a>
        </div>

        <div class='reveal principle-card'>
          <div class='principle-icon'>🛠️</div>
          <h3 class='principle-title'>Developer Standards</h3>
          <p class='principle-body'>
            Shared TypeScript and Biome presets keep all Coral repos aligned.
          </p>
          <a href='https://docs.getcoral.dev/libraries/npm-packages/' class='card-link'>
            View package catalog
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PHILOSOPHY -->
  <section id='principles' class='section-philosophy'>
    <div class='section-inner'>
      <div class='reveal section-header'>
        <p class='section-eyebrow' style='color: var(--coral);'>Philosophy</p>
        <h2 class='section-title'>Built on three rules.</h2>
      </div>

      <div class='principles-grid'>
        {
          [
            {
              icon: '🐳',
              title: 'Docker native',
              body: 'Every module ships as a Docker image. One Compose file, one command, running on your NAS. No cloud dependency, no internet required at the bar.',
            },
            {
              icon: '🪸',
              title: 'Jellyfin as source of truth',
              body: 'Modules never share a database. If two need to talk, they do it through the Jellyfin API. Clean boundaries, no tight coupling.',
            },
            {
              icon: '🔓',
              title: 'MIT forever',
              body: 'Open source, no paid tier, no SaaS. GitHub Sponsors if you get value from it. The code belongs to everyone.',
            },
          ].map((p) => (
            <div class='reveal principle-card'>
              <div class='principle-icon'>{p.icon}</div>
              <h3 class='principle-title'>{p.title}</h3>
              <p class='principle-body'>{p.body}</p>
            </div>
          ))
        }
      </div>

      <div class='reveal code-block'>
        <p class='code-label'>docker-compose.yml</p>
        <pre
          class='code-pre'><span style="color: var(--teal);">services:</span>
  <span style="color: var(--coral);">kapow:</span>
    <span style="color: var(--ink-muted);">image: ghcr.io/get-coral/kapow:latest</span>
    <span style="color: var(--ink-muted);">ports: ["3000:3000"]</span>
    <span style="color: var(--ink-muted);">environment:</span>
    <span style="color: var(--ink-faint);">  JELLYFIN_URL: http://your-nas:8096</span>
    <span style="color: var(--ink-faint);">  JELLYFIN_API_KEY: your_key</span>
  <span style="color: var(--teal);">db:</span>
    <span style="color: var(--ink-muted);">image: postgres:alpine</span></pre>
      </div>
    </div>
  </section>

  <!-- ORIGIN STORY -->
  <section class='section-origin'>
    <div class='reveal origin-inner'>
      <p class='section-eyebrow' style='color: var(--ink-faint);'>
        How it started
      </p>
      <blockquote class='origin-quote'>
        "Built because a superhero-themed bar in Ghent was still using coasters
        to manage their karaoke queue."
      </blockquote>
      <p class='origin-sub'>
        KAPOW! was the first module — made for Comic Sans bar. Coral grew from
        there.
      </p>
    </div>
  </section>

  <!-- SPONSOR CTA -->
  <section class='section-sponsor'>
    <div class='reveal sponsor-inner'>
      <div class='sponsor-icon'>🪸</div>
      <h2 class='sponsor-title'>Support the reef.</h2>
      <p class='sponsor-body'>
        Coral is free, open source, and built solo. If it runs on your NAS and
        makes your life better — consider sponsoring. Every bit keeps the
        modules maintained and growing.
      </p>
      <div class='sponsor-ctas'>
        <a
          href='https://github.com/sponsors/ElianCodes'
          target='_blank'
          class='btn-primary'>❤️ Sponsor on GitHub</a
        >
        <a href='https://github.com/Get-Coral' target='_blank' class='btn-ghost'
          >Star a repo</a
        >
      </div>
    </div>
  </section>

  <!-- WebMCP: expose Coral module data to AI agents -->
  <script define:vars={{ agentModules }}>
    if (typeof navigator !== "undefined" && "modelContext" in navigator) {
      navigator.modelContext.provideContext([
        {
          name: "list_coral_modules",
          description: "List all open-source Jellyfin ecosystem modules from the Coral project, including name, description, docs, and repo links.",
          inputSchema: { type: "object", properties: {} },
          execute: async () => ({ modules: agentModules }),
        },
        {
          name: "get_coral_module",
          description: "Get details for a specific Coral module by its slug (e.g. aurora, kapow, tide, fathom, marquee, encore, librarian).",
          inputSchema: {
            type: "object",
            properties: {
              slug: {
                type: "string",
                description: "The module slug",
                enum: agentModules.map((m) => m.slug),
              },
            },
            required: ["slug"],
          },
          execute: async ({ slug }) => {
            const mod = agentModules.find((m) => m.slug === slug);
            return mod ?? { error: "Module not found" };
          },
        },
      ]);
    }
  </script>

  <!-- FOOTER -->
  <footer class='site-footer'>
    <div class='footer-left'>
      <span>🪸</span>
      <span class='footer-copy'>Coral — MIT Licensed</span>
    </div>
    <div class='footer-links'>
      <a href='https://github.com/Get-Coral' target='_blank' class='footer-link'
        >GitHub</a
      >
      <a href='https://elian.codes' target='_blank' class='footer-link'
        >elian.codes</a
      >
    </div>
  </footer>
</Layout>
