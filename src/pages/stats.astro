---
import Layout from "@layouts/Default.astro";

const npmPackages = [
	{
		name: "@get-coral/biome-config",
		npm: "@get-coral/biome-config",
		repo: "https://github.com/Get-Coral/coral/tree/main/dev-standards/packages/biome-config",
	},
	{
		name: "@get-coral/ui",
		npm: "@get-coral/ui",
		repo: "https://github.com/Get-Coral/coral-ui",
	},
	{
		name: "@get-coral/jellyfin",
		npm: "@get-coral/jellyfin",
		repo: "https://github.com/Get-Coral/Jellyfin",
	},
	{
		name: "@get-coral/tsconfig",
		npm: "@get-coral/tsconfig",
		repo: "https://github.com/Get-Coral/coral/tree/main/dev-standards/packages/tsconfig",
	},
	{
		name: "create-coral",
		npm: "create-coral",
		repo: "https://github.com/Get-Coral/create-coral",
	},
];

const dockerNamespace = "getcoral";
const dockerImages = [
	"aurora",
	"kapow",
	"fathom",
	"marquee",
	"encore",
	"librarian",
	"tide",
];

const GH_SVG = `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`;
const chartPackages = npmPackages.map((pkg) => pkg.npm);
---

<Layout
  title='Coral Stats | NPM Downloads and Docker Pulls'
  description='Track public Coral ecosystem metrics including weekly npm downloads and Docker Hub pull counts for Coral modules.'
>
  <nav class='site-nav'>
    <a href='/' class='nav-logo'>
      <span>🪸</span>
      <span class='nav-logo-text'>Coral</span>
    </a>
    <div class='nav-links'>
      <a href='/' class='nav-pill'>Home</a>
      <a href='/stats' class='nav-pill'>Stats</a>
      <a
        href='https://github.com/Get-Coral'
        target='_blank'
        class='nav-pill nav-pill-icon'
      >
        <Fragment set:html={GH_SVG} />
        <span class='nav-gh-text'>GitHub</span>
      </a>
    </div>
  </nav>

  <main class='stats-page'>
    <section class='stats-hero reveal visible'>
      <p class='hero-kicker'>Public Metrics</p>
      <h1>Coral ecosystem stats</h1>
      <div class='hero-chips'>
        <span class='chip'
          >{npmPackages.length} npm {
            npmPackages.length === 1 ? 'package' : 'packages'
          }</span
        >
        <span class='chip'>{dockerImages.length} docker images</span>
      </div>
    </section>

    <section class='stats-grid'>
      <article class='stats-card reveal visible'>
        <h2>NPM Downloads</h2>
        <p class='card-sub'>
          Weekly download badges for published Coral packages and tooling.
        </p>
        <ul class='metric-list'>
          {
            npmPackages.map((pkg) => (
              <a
                href={`https://www.npmjs.com/package/${pkg.npm}`}
                target='_blank'
                rel='noreferrer'
                class='metric-item metric-item-link'
              >
                <div class='metric-meta'>
                  <span class='metric-name'>{pkg.name}</span>
                  <span class='metric-link'>open npm</span>
                </div>
                <img
                  src={`https://img.shields.io/npm/dw/${encodeURIComponent(pkg.npm)}?label=weekly%20downloads&color=2dd4bf&labelColor=0b1820`}
                  alt={`Weekly npm downloads for ${pkg.name}`}
                  loading='lazy'
                />
              </a>
            ))
          }
        </ul>
      </article>

      <article class='stats-card reveal visible'>
        <h2>Docker Pulls</h2>
        <p class='card-sub'>
          Docker Hub pull count badges for Coral module images.
        </p>
        <ul class='metric-list'>
          {
            dockerImages.map((image) => (
              <a
                href={`https://hub.docker.com/r/${dockerNamespace}/${image}`}
                target='_blank'
                rel='noreferrer'
                class='metric-item metric-item-link'
              >
                <div class='metric-meta'>
                  <span class='metric-name'>{image}</span>
                  <span class='metric-link'>open docker</span>
                </div>
                <img
                  src={`https://img.shields.io/docker/pulls/${dockerNamespace}/${image}?label=pulls&color=ff6b6b&labelColor=0b1820`}
                  alt={`Docker pulls for ${dockerNamespace}/${image}`}
                  loading='lazy'
                />
              </a>
            ))
          }
        </ul>
      </article>
    </section>

    <section class='stats-card chart-card reveal visible'>
      <div class='chart-header'>
        <div>
          <h2>Downloads Over Time</h2>
          <p class='card-sub'>Daily npm downloads for the last 90 days.</p>
        </div>
        <label class='chart-select-label'>
          Package
          <select id='downloads-package-select' class='chart-select'>
            {
              npmPackages.map((pkg) => (
                <option value={pkg.npm}>{pkg.name}</option>
              ))
            }
          </select>
        </label>
      </div>

      <div class='chart-meta' id='downloads-chart-meta'>
        <span class='chip'>Loading chart...</span>
      </div>

      <div class='chart-wrap'>
        <div id='downloads-chart-empty' class='chart-empty' hidden>
          No download history is available yet for this package on npm.
        </div>
        <svg
          id='downloads-chart'
          class='downloads-chart'
          viewBox='0 0 800 280'
          preserveAspectRatio='none'
          role='img'
          aria-label='NPM downloads over time chart'
        >
          <path id='downloads-chart-area' class='chart-area' d=''></path>
          <path id='downloads-chart-line' class='chart-line' d=''></path>
        </svg>
      </div>
    </section>
  </main>
</Layout>

<script define:vars={{ chartPackages }} is:inline>
  const select = document.getElementById('downloads-package-select');
  const chart = document.getElementById('downloads-chart');
  const chartLine = document.getElementById('downloads-chart-line');
  const chartArea = document.getElementById('downloads-chart-area');
  const chartMeta = document.getElementById('downloads-chart-meta');
  const chartEmpty = document.getElementById('downloads-chart-empty');

  const width = 800;
  const height = 280;
  const padX = 24;
  const padTop = 16;
  const padBottom = 28;

  function summarize(data) {
    const total = data.reduce((sum, p) => sum + p.downloads, 0);
    const peak = data.reduce((max, p) => Math.max(max, p.downloads), 0);
    return { total, peak };
  }

  function setMeta(data, pkg) {
    const { total, peak } = summarize(data);
    chartMeta.innerHTML = `
      <span class="chip">${pkg}</span>
      <span class="chip">90d total: ${total.toLocaleString()}</span>
      <span class="chip">peak day: ${peak.toLocaleString()}</span>
    `;
  }

  function drawChart(points) {
    if (!chartEmpty) return;
    if (!points.length) {
      chartEmpty.hidden = false;
      chartLine.setAttribute('d', '');
      chartArea.setAttribute('d', '');
      return;
    }

    chartEmpty.hidden = true;

    const maxY = Math.max(...points.map((p) => p.downloads), 1);
    const minY = 0;
    const plotW = width - padX * 2;
    const plotH = height - padTop - padBottom;

    const coords = points.map((p, i) => {
      const x = padX + (i / Math.max(points.length - 1, 1)) * plotW;
      const y =
        padTop + (1 - (p.downloads - minY) / (maxY - minY || 1)) * plotH;
      return { x, y };
    });

    const lineD = coords
      .map(
        (c, i) => `${i === 0 ? 'M' : 'L'} ${c.x.toFixed(2)} ${c.y.toFixed(2)}`,
      )
      .join(' ');

    const first = coords[0];
    const last = coords[coords.length - 1];
    const areaD = `${lineD} L ${last.x.toFixed(2)} ${(height - padBottom).toFixed(2)} L ${first.x.toFixed(2)} ${(height - padBottom).toFixed(2)} Z`;

    chartLine.setAttribute('d', lineD);
    chartArea.setAttribute('d', areaD);
  }

  async function loadPackage(pkg) {
    if (!chartEmpty) return;
    chartMeta.innerHTML = `<span class="chip">Loading ${pkg}...</span>`;
    try {
      const res = await fetch(
        `https://api.npmjs.org/downloads/range/last-90-days/${encodeURIComponent(pkg)}`,
      );
      if (!res.ok)
        throw new Error(`Failed to load npm downloads: ${res.status}`);
      const json = await res.json();
      const downloads = Array.isArray(json.downloads) ? json.downloads : [];

      // npm can return a placeholder single point (2015-01-10, 0 downloads) for unpublished packages.
      const isPlaceholder =
        downloads.length <= 1 &&
        (downloads[0]?.day || '').startsWith('2015-01-10') &&
        (downloads[0]?.downloads || 0) === 0;

      const validDownloads = isPlaceholder
        ? []
        : downloads.filter(
            (point) => Number.isFinite(point.downloads) && point.downloads >= 0,
          );

      drawChart(validDownloads);
      if (validDownloads.length) {
        setMeta(validDownloads, pkg);
      } else {
        chartMeta.innerHTML = `
          <span class="chip">${pkg}</span>
          <span class="chip">No recent npm downloads data</span>
        `;
      }
    } catch (_error) {
      chartLine.setAttribute('d', '');
      chartArea.setAttribute('d', '');
      chartEmpty.hidden = false;
      chartMeta.innerHTML = `<span class="chip">Could not load chart data</span>`;
    }
  }

  if (select && chart && chartLine && chartArea && chartMeta && chartEmpty) {
    const initial = select.value || chartPackages[0];
    loadPackage(initial);
    select.addEventListener('change', (event) => {
      const target = event.target;
      if (target && target.value) loadPackage(target.value);
    });
  }
</script>

<style>
  .stats-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: 7rem 1.25rem 3rem;
  }

  .stats-hero {
    border: 1px solid var(--border);
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.05),
      rgba(45, 212, 191, 0.04)
    );
    border-radius: 18px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .hero-kicker {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--teal);
    margin-bottom: 0.5rem;
  }

  .stats-hero h1 {
    font-size: clamp(1.8rem, 5vw, 3rem);
    margin-bottom: 0.6rem;
  }

  .stats-hero p {
    color: var(--ink-muted);
    max-width: 70ch;
  }

  .hero-chips {
    margin-top: 1rem;
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    font-size: 0.8rem;
    color: var(--ink);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }

  .stats-card {
    border: 1px solid var(--border);
    background: var(--surface);
    border-radius: 18px;
    padding: 1.25rem;
  }

  .chart-card {
    margin-top: 1rem;
  }

  .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .chart-select-label {
    display: grid;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .chart-select {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.04);
    color: var(--ink);
    font-size: 0.9rem;
    padding: 0.5rem 0.6rem;
    min-width: 220px;
  }

  .chart-meta {
    margin: 0.8rem 0;
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .chart-wrap {
    border: 1px solid var(--border);
    border-radius: 14px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.04),
      rgba(255, 255, 255, 0.01)
    );
    padding: 0.75rem;
    position: relative;
  }

  .chart-empty {
    position: absolute;
    inset: 0.75rem;
    display: grid;
    place-items: center;
    text-align: center;
    color: var(--ink-muted);
    font-size: 0.95rem;
    border: 1px dashed var(--border);
    border-radius: 10px;
    background: rgba(11, 24, 32, 0.78);
    z-index: 1;
  }

  .downloads-chart {
    display: block;
    width: 100%;
    height: 280px;
  }

  .chart-area {
    fill: rgba(45, 212, 191, 0.18);
  }

  .chart-line {
    fill: none;
    stroke: var(--teal);
    stroke-width: 3;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  .stats-card h2 {
    font-size: 1.35rem;
    margin-bottom: 0.3rem;
  }

  .card-sub {
    color: var(--ink-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .metric-list {
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }

  .metric-item {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    padding: 0.75rem;
    display: grid;
    gap: 0.5rem;
  }

  .metric-item-link {
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .metric-item-link:hover {
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-1px);
  }

  .metric-item-link:focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 2px;
  }

  .metric-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .metric-name {
    color: var(--ink);
    text-decoration: none;
    font-weight: 500;
    text-transform: capitalize;
  }

  .metric-link {
    color: var(--teal);
    text-decoration: none;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .metric-item img {
    max-width: 100%;
    height: 20px;
  }

  .stats-note {
    margin-top: 1rem;
    border: 1px dashed var(--border);
    border-radius: 14px;
    padding: 1rem;
    color: var(--ink-muted);
    background: rgba(255, 255, 255, 0.02);
  }

  .stats-note h3 {
    color: var(--ink);
    margin-bottom: 0.45rem;
    font-size: 1.05rem;
  }

  .stats-note p + p {
    margin-top: 0.4rem;
  }
</style>
